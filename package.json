{
  "name": "upnp-nat",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rm -rf dist/ && bun build --compile --production --outfile dist/upnp-nat src/index.ts",
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "nat-upnp": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nat-upnp": "^1.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
